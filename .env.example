# Dev auto-sync target. Set to your Obsidian vault root.
# When set, `pnpm dev` syncs dist/ → $OBSIDIAN_VAULT_PATH/.obsidian/plugins/obsidian-better-image-helper/
# and writes a .hotreload marker so the obsidian-hot-reload plugin auto-reloads.
OBSIDIAN_VAULT_PATH=/absolute/path/to/your/vault

# Or point directly at the plugin dir (overrides OBSIDIAN_VAULT_PATH logic):
# OBSIDIAN_PLUGIN_PATH=/absolute/path/to/.obsidian/plugins/obsidian-better-image-helper

# Build-time only (inlined into bundle by node-globals plugin). Leave blank for release builds.
ALI_AK=
ALI_SK=
